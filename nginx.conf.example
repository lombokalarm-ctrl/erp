server {
    listen 80;
    server_name apps.lombokhomes.my.id;

    # Backend API routing
    location /erp/api/ {
        # Strip the /erp prefix before passing to backend
        rewrite ^/erp/(.*) /$1 break;
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Frontend routing
    location /erp/ {
        # Assuming you copy the built 'dist' folder to /var/www/erp
        alias /var/www/erp/;
        try_files $uri $uri/ /erp/index.html;
    }

    # Optional: Redirect / to /erp if this is a dedicated ERP subdomain
    # location = / {
    #     return 301 /erp/;
    # }
}